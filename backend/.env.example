PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/teamflow

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Comma separated list of allowed origins (admin + employee frontends)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# use httpOnly cookie for the JWT instead of returning it only in body
USE_COOKIE_AUTH=true

LOG_LEVEL=info

# general API rate limit (per IP, per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
# stricter limit specifically on /auth/login
AUTH_RATE_LIMIT_MAX=10

MONGO_MAX_POOL_SIZE=20
